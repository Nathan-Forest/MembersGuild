# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=membersguild
DB_PASSWORD=change_this_to_a_secure_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. No ! character (causes bash expansion issues).
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_32_char_minimum_secret

# ── URLs ──────────────────────────────────────────────────────────────────────
# The public-facing URL of the frontend (used for CORS allow list)
FRONTEND_URL=https://membersguild.com.au

# ── Email (SendGrid or AWS SES — Phase 9) ────────────────────────────────────
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@membersguild.com.au

# ── Stripe (Phase 8 — platform billing) ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS S3 (Phase 9 — file storage) ─────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=membersguild-uploads
# AWS_REGION=ap-southeast-2
